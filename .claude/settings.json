{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Jarvis default permissions - safe operations without prompting",
  "version": "1.2",

  "plansDirectory": ".claude/plans",
  "mcpToolSearch": "auto:15",

  "hooks": {
    "Setup": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/setup-hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/precompact-analyzer.js"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/exit-guard.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/insight-capture.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/refresh-ccusage-cache.sh &"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/bash-safety-guard.js"
          }
        ]
      },
      {
        "matcher": "^(Read|Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/bash-safety-guard.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/context-injector.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-clear-context-prep.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/prompt-timestamp.sh"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/orchestration-detector.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/self-correction-capture.js",
            "async": true
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/permission-gate.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/wiggum-loop-tracker.js",
            "async": true
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/milestone-coordinator.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/context-health-monitor.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/ulfhedthnar-detector.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$|^mcp__git__git_commit$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/cross-project-commit-tracker.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/docker-monitor.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^(Task|Skill|WebSearch|WebFetch|EnterPlanMode|Read)$|^mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/usage-tracker.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^(Read|Bash|Grep|Glob|WebFetch|WebSearch)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/observation-tracker.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^TodoWrite$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/milestone-coordinator.js"
          }
        ]
      },
      {
        "matcher": "^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/memory-mirror.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^(Task|Bash)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/ulfhedthnar-detector.js"
          }
        ]
      },
      {
        "matcher": "^(Task|TaskCreate|TaskUpdate)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/virgil-tracker.js",
            "async": true
          }
        ]
      },
      {
        "matcher": "^ExitPlanMode$",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/plan-tracker.js",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/session-tracker.js",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/subagent-stop.js",
            "async": true
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/ulfhedthnar-detector.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/virgil-tracker.js",
            "async": true
          }
        ]
      }
    ]
  },

  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/nathanielcannon/Claude/AIFred-Pro-Dev",
      "/Users/nathanielcannon/Claude/Projects",
      "/Users/nathanielcannon/Claude/Shared_Projects",
      "/Users/nathanielcannon/Claude/Jarvis-Dev"
    ],
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Agent",
      "mcp__*",
      "Read(/Users/nathanielcannon/Claude/Jarvis/.claude/secrets/**)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(**/.env)",
      "Write(/Users/nathanielcannon/Claude/Archive/AIfred/**)",
      "Edit(/Users/nathanielcannon/Claude/Archive/AIfred/**)",
      "Write(/Users/nathanielcannon/Claude/AIFred-Pro/**)",
      "Edit(/Users/nathanielcannon/Claude/AIFred-Pro/**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /home/*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R:*)"
    ]
  }
}
