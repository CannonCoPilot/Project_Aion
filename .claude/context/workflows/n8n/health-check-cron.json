{
  "updatedAt": "2026-02-19T16:04:02.419Z",
  "createdAt": "2026-02-19T16:04:02.419Z",
  "id": "wTLsa71OChm0jNsa",
  "name": "Jarvis - Hourly Health Check",
  "description": null,
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "id": "cron-trigger",
      "name": "Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      }
    },
    {
      "id": "check-qdrant",
      "name": "Check Qdrant",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        150
      ],
      "parameters": {
        "method": "GET",
        "url": "http://jarvis-qdrant:6333/healthz",
        "options": {
          "timeout": 5000
        },
        "onError": "continueRegularOutput"
      }
    },
    {
      "id": "check-neo4j",
      "name": "Check Neo4j",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "http://jarvis-neo4j:7474",
        "options": {
          "timeout": 5000
        },
        "onError": "continueRegularOutput"
      }
    },
    {
      "id": "check-ollama",
      "name": "Check Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        450
      ],
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:11434/api/tags",
        "options": {
          "timeout": 5000
        },
        "onError": "continueRegularOutput"
      }
    },
    {
      "id": "log-qdrant",
      "name": "Log Qdrant",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        750,
        150
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jarvis_health_events (service, status, response_time_ms) VALUES ('qdrant', CASE WHEN $1::int = 200 THEN 'healthy' ELSE 'unhealthy' END, 0)",
        "options": {
          "queryReplacement": "={{ $json.statusCode }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "uWm2xENqCgVCjg4O",
          "name": "Jarvis Postgres"
        }
      }
    },
    {
      "id": "log-neo4j",
      "name": "Log Neo4j",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        750,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jarvis_health_events (service, status, response_time_ms) VALUES ('neo4j', CASE WHEN $1::int = 200 THEN 'healthy' ELSE 'unhealthy' END, 0)",
        "options": {
          "queryReplacement": "={{ $json.statusCode }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "uWm2xENqCgVCjg4O",
          "name": "Jarvis Postgres"
        }
      }
    },
    {
      "id": "log-ollama",
      "name": "Log Ollama",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        750,
        450
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jarvis_health_events (service, status, response_time_ms) VALUES ('ollama', CASE WHEN $1::int = 200 THEN 'healthy' ELSE 'unhealthy' END, 0)",
        "options": {
          "queryReplacement": "={{ $json.statusCode }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "uWm2xENqCgVCjg4O",
          "name": "Jarvis Postgres"
        }
      }
    }
  ],
