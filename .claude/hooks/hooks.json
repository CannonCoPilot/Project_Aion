{
  "description": "Jarvis Stop hooks — Ralph Loop re-feed + exit guard for /end-session enforcement",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/exit-guard.sh"
          }
        ]
      }
    ]
  }
}
