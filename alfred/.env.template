# AIFred-Pro Environment Configuration Template
# Copy this file to .env and fill in the required values:
#   cp .env.template .env
# Or run the setup script which generates .env interactively:
#   bash scripts/setup-pulse.sh

# ─────────────────────────────────────────────
# Pulse Task Service — Database
# ─────────────────────────────────────────────

# PostgreSQL password for the Pulse database user (required)
PULSE_DB_PASSWORD=

# Database name (default: pulse)
PULSE_DB_NAME=pulse

# Database user (default: pulse)
PULSE_DB_USER=pulse

# ─────────────────────────────────────────────
# Pulse Task Service — Network
# ─────────────────────────────────────────────

# Port Pulse listens on (default: 8700)
PULSE_PORT=8700

# Log level: debug, info, warning, error (default: info)
PULSE_LOG_LEVEL=info

# ─────────────────────────────────────────────
# Paths
# ─────────────────────────────────────────────

# Absolute path to this AIFred-Pro directory (default: current directory)
# Used by docker-compose to mount config files and export directories.
AIFRED_PATH=

# Path to Pulse source code for building the Docker image.
# Leave blank to use the bundled pulse/ submodule if present,
# or set to an absolute path to your Pulse checkout.
# Example: /home/yourname/Code/pulse
PULSE_SOURCE_PATH=./pulse

# ─────────────────────────────────────────────
# Nexus Dashboard
# ─────────────────────────────────────────────

# Port the dashboard listens on (default: 8600)
DASHBOARD_PORT=8600

# Service token for Pulse API authentication
PULSE_DASHBOARD_TOKEN=

# Default workspace name shown in dashboard
DEFAULT_WORKSPACE=MyProject

# Web Push notifications (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ─────────────────────────────────────────────
# Notifications (optional)
# ─────────────────────────────────────────────

# Telegram bot for critical alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook for Docker restart notifications
WEBHOOK_URL=
WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Infrastructure (optional)
# ─────────────────────────────────────────────

# NAS mount point for health checks
NAS_MOUNT_PATH=

# Public URL for endpoint health checks
PUBLIC_HEALTH_URL=

# Obsidian vault path
OBSIDIAN_VAULT_PATH=
