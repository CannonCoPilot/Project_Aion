erDiagram

    %% ── Geography & World ─────────────────────────────────

    %% Top-level world record (one per DF export) (1 rows)
    worlds {
        int id "PK"
        text name
        text alt_name
        text import_path
        timestamptz imported_at
    }

    %% Continents and major landmasses (100 rows)
    landmasses {
        int id "PK"
        int world_id "PK,FK"
        text name
        text coord_1
        text coord_2
    }

    %% Named peaks, volcanoes (16 rows)
    mountain_peaks {
        int id "PK"
        int world_id "PK,FK"
        text name
        text coords
        int height
        bool is_volcano
    }

    %% Surface biome regions (2,278 rows)
    regions {
        int id "PK"
        int world_id "PK,FK"
        text name
        text type
        text coords
    }

    %% Cavern layers, magma sea, underworld (1,445 rows)
    underground_regions {
        int id "PK"
        int world_id "PK,FK"
        text type
        int depth
        text coords
    }

    %% Cities, fortresses, lairs, camps (2,154 rows)
    sites {
        int id "PK"
        int world_id "PK,FK"
        text name
        text type
        int coord_x
        int coord_y
        text coords
        int owner_entity_id
        jsonb details
        float importance_score
    }

    %% Buildings within sites (temples, tombs, libraries) (1,833 rows)
    structures {
        int id "PK"
