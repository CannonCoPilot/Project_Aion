    WATCHER --> LH
    WATCHER --> ANN
    WATCHER --> FS
    WATCHER --> SQ
    WATCHER -->|"13 sections\nraw dump"| STAGING

    XML -->|"one-time\nimport"| PARSER
    PARSER --> HF
    PARSER --> HE
    PARSER --> ENT

    HF -->|"SELECT"| PAGES
    HE -->|"SELECT"| PAGES
    ENT -->|"SELECT"| PAGES

    LIVE -.-|"❌ NO\nCONNECTION"| LEGENDS

