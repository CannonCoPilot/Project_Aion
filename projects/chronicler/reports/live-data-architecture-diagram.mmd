flowchart TD
    subgraph GAME["🎮 DF Game Memory"]
        MEM["df.global.*"]
    end

    subgraph CAPTURE["Live Capture Pipeline"]
        BRIDGE["Bridge Lua\n26 sections"]
        WATCHER["Watcher ETL"]
    end

    subgraph LIVE["Live Tables — 13 tables"]
        UNITS["units"]
        UE["unit_events"]
        FD["fortress_denizens"]
        LH["live_history"]
        ANN["announcements"]
        FS["fortress_state"]
        SQ["squads + 6 more"]
    end

    STAGING["☠️ lua_probes\n13 sections\nRAW JSONB\nDEAD END"]

