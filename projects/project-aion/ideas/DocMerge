## Orchestration Pseudocode for Main Agent

```python name=hds_orchestrator.py
async def hierarchical_delta_synthesis(documents: List[Path], output: Path):
    """
    Main orchestration function for Hierarchical Delta Synthesis.
    Spawns and coordinates all sub-agents through the five phases.
    """
    
    # Phase 0: Structural Discovery
    header_tasks = [
        spawn_agent("structural_scout", doc) 
        for doc in documents
    ]
    headers = await gather_all(header_tasks)
    
    taxonomy = await spawn_agent("taxonomy_architect", headers)
    
    # Phase 1: Anchor Selection
    coverage_tasks = [
        spawn_agent("coverage_scorer", doc, taxonomy)
        for doc in documents
    ]
    scores = await gather_all(coverage_tasks)
    
    master_idx = argmax(scores, key=lambda s: s.depth_score)
    master = documents[master_idx]
    subdocs = [d for i, d in enumerate(documents) if i != master_idx]
    
    master_index = await spawn_agent("index_builder", master, taxonomy)
    
    # Phase 2: Parallel Delta Extraction
    delta_tasks = [
        spawn_agent(
            "delta_extractor",
            master=master,           # Will be cached
            master_index=master_index,
            taxonomy=taxonomy,
            subdoc=subdoc
        )
        for subdoc in subdocs
    ]
    deltas = await gather_all(delta_tasks)
    
    # Phase 3: Logarithmic Delta Consolidation  
    while len(deltas) > 1:
        next_round = []
        consolidation_tasks = []
        
        for i in range(0, len(deltas), 2):
            if i + 1 < len(deltas):
                consolidation_tasks.append(
                    spawn_agent(
                        "delta_consolidator",
                        delta_a=deltas[i],
                        delta_b=deltas[i+1],
                        master_index=master_index,
                        taxonomy=taxonomy
                    )
                )
            else:
                next_round.append(deltas[i])  # Odd one passes through
        
        consolidated = await gather_all(consolidation_tasks)
        deltas = consolidated + next_round
    
    final_delta = deltas[0]
    
    # Phase 4: Final Assembly
    result = await spawn_agent(
        "final_assembler",
        master=master,
        final_delta=final_delta,
        taxonomy=taxonomy
    )
    
    await write_file(output, result.content)
    
    return {
        "master_document": output,
        "conflict_report": result.conflict_report,
        "completeness": result.completeness_checklist
    }
```

