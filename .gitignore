# AIfred .gitignore

# Local settings (user-specific)
.claude/settings.local.json

# Scratch files (temp workspace, never tracked)
.claude/scratch/

# Logs (rotated, can be large)
.claude/logs/*.jsonl
.claude/logs/*.log
.claude/logs/*.json
.claude/logs/archive/
.claude/logs/.current-session
.claude/logs/.session-activity
.claude/logs/latest
.claude/logs/debug.log

# Runtime context files (regenerated each session)
.claude/context/.watcher-*
.claude/context/.jicm-*
.claude/context/.command-output
.claude/context/.context-captured*
.claude/context/*.signal
.claude/context/.preservation-manifest.json
.claude/context/.idle-hands-*
.claude/context/.clear-sent.signal
.claude/context/.continuation-injected.signal
.claude/context/.compression-in-progress
.claude/context/.exit-guard-passed
.claude/context/.last-prompt-ts*
.claude/context/.ccusage-blocks.json
.claude/context/.context-display.txt
.claude/context/.statusline-context.json

# Tool output offloading (temp files for large results)
.claude/context/.tool-output/

# Compressed context (restored on /clear, not persisted)
.claude/context/.compressed-context-ready.md
.claude/context/.in-progress-ready.md
.claude/context/.active-tasks.txt
.claude/context/.active-plan
.claude/context/.command-handler.pid
.claude/context/.ennoia-*
.claude/context/.virgil-*
.claude/context/.soft-restart-checkpoint.md
.claude/context/.prep-override
.claude/context/.compression-status
.claude/context/export_chat.txt
.claude/context/exports/

# JICM session data (regenerated each cycle, can be large)
.claude/context/jicm/archive/
.claude/context/jicm/sessions/
.claude/context/jicm/.compression-status
.claude/context/jicm/.current-session-id

# Chat exports (auto-generated before compress/clear, can be large)
.claude/exports/

# Memory mirror (auto-synced from ~/.claude/projects/.../memory/)
.claude/context/memory/MEMORY.md

# Symlinks to external ~/.claude/ scripts (originals live outside project)
.claude/scripts/jarvis-statusline.sh
.claude/scripts/update-context-cache.sh
.claude/scripts/statusline-debug-capture.sh
.claude/hooks/update-context-cache.js

# State files (runtime only)
.claude/state/components/*.json

# Agent sessions (transient)
.claude/agents/sessions/*.md

# MCP configuration (may contain paths)
.mcp.json

# OpenCode local settings
opencode.local.json

# User-specific paths (create from template)
paths-registry.yaml

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node (if using node for scripts)
node_modules/

# Python (if using python for scripts)
__pycache__/
*.pyc
.venv/
venv/

# Script configuration (contains sensitive data)
scripts/config.sh
# Sensitive credentials - never commit
.claude/config/credentials.local.yaml
.claude/secrets/
*.credentials
*.secret
.claude/ralph-loop.local.md

# Telemetry and JICM logs (subdirectories not covered by logs/*.jsonl glob)
.claude/logs/telemetry/
.claude/logs/jicm/

# Archive logs (rotated operational logs, can be large)
.claude/archive/logs/
.claude/logs/*.log.*

# Large experiment artifacts (28MB+ transcript captures)
.claude/reports/testing/experiment-7-captures/clean-transcript.jsonl

# Generated analysis output
jarvis_graph.md

# Screenshots (large binary files — use external storage for images)
docs/reports/*.png
projects/mtg-card-sales/*.png
projects/mtg-card-sales/archived/*.png
infrastructure/.venv/
infrastructure/.env

# Cloned reference repos moved to ~/Claude/GitRepos/ (2026-02-20)
# Kept for safety in case any are re-cloned here accidentally
projects/df-ai/
projects/df-narrator/
projects/df-structures/
projects/dfhack-client-python/
projects/DwarfFortressLogger/
projects/myDFHackScripts/
projects/weblegends/
projects/claude-code-docs/

# Token compression metrics (JSONL can be large; archive contains gzipped data)
.claude/metrics/

# Embedded git repos (infrastructure tools with their own .git)
infrastructure/qwen3-embeddings-mlx/

# LanceDB (local-rag MCP runtime data)
lancedb/
