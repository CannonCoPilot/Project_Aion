      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      const tab = document.getElementById('dtab-' + tabName);
      const content = document.getElementById('dtab-content-' + tabName);
      if (tab) tab.classList.add('active');
      if (content) content.classList.add('active');
      // Update URL hash
      history.replaceState(null, '', '#tab=' + tabName);
    }

    // Restore tab from URL hash on load
    document.addEventListener('DOMContentLoaded', function() {
      const hash = location.hash;
      if (hash && hash.startsWith('#tab=')) {
        switchDetailTab(hash.replace('#tab=', ''));
      }
    });
  </script>
  <!-- Entity link hover popovers -->
  <script>
  (function() {
    const popoverCache = {};

    function initPopovers() {
      document.querySelectorAll('.entity-link[data-entity-type][data-entity-id]').forEach(el => {
        if (el._tippyInit) return;
        el._tippyInit = true;
        tippy(el, {
          theme: 'chronicler',
          delay: [300, 0],
          allowHTML: true,
          interactive: true,
          placement: 'top',
          content: 'Loading...',
          onShow(instance) {
            const type = el.dataset.entityType;
            const id = el.dataset.entityId;
            const key = type + ':' + id;
            if (popoverCache[key]) {
              instance.setContent(popoverCache[key]);
              return;
            }
            fetch('/api/popover/' + type + '/' + id)
              .then(r => r.json())
              .then(data => {
                const html = renderPopover(data);
                popoverCache[key] = html;
                instance.setContent(html);
              })
              .catch(() => instance.setContent('<span class="text-stone-500">Failed to load</span>'));
          }
        });
      });
    }

    function renderPopover(d) {
      if (d.error) return '<span class="text-stone-500">' + d.error + '</span>';
      let html = '<div class="pop-name">' + escHtml(d.name || '?') + '</div>';

      if (d.type === 'hf') {
        const badges = (d.badges || []).map(b =>
          '<span class="pop-badge" style="background:' + badgeColor(b) + '">' + b + '</span>'
        ).join('');
        html += '<div>' + badges;
        html += '<span class="pop-badge" style="background:' + (d.alive ? '#22c55e30;color:#22c55e' : '#ef444430;color:#ef4444') + '">' + (d.alive ? 'alive' : 'dead') + '</span>';
        html += '</div>';
        html += '<div class="pop-meta">' + escHtml(d.race || '') + (d.caste ? ' (' + escHtml(d.caste) + ')' : '') + '</div>';
        if (d.birth_year) html += '<div class="pop-meta">Born: Year ' + d.birth_year + (d.death_year ? ' / Died: Year ' + d.death_year : '') + '</div>';
        if (d.kill_count) html += '<div class="pop-meta">Kills: ' + d.kill_count + '</div>';
      } else if (d.type === 'site') {
        html += '<div class="pop-meta">' + escHtml(d.site_type || '') + (d.owner ? ' / ' + escHtml(d.owner) : '') + '</div>';
        if (d.coord_x != null) html += '<div class="pop-meta">(' + d.coord_x + ', ' + d.coord_y + ')</div>';
      } else if (d.type === 'entity') {
        html += '<div class="pop-meta">' + escHtml(d.entity_type || '') + ' / ' + escHtml(d.race || '') + '</div>';
      } else if (d.type === 'artifact') {
        html += '<div class="pop-meta">' + escHtml(d.item_type || '') + (d.material ? ' (' + escHtml(d.material) + ')' : '') + '</div>';
        if (d.holder) html += '<div class="pop-meta">Held by: ' + escHtml(d.holder) + '</div>';
      } else if (d.type === 'structure') {
        html += '<div class="pop-meta">' + escHtml(d.structure_type || '') + (d.site ? ' at ' + escHtml(d.site) : '') + '</div>';
      } else {
        // Generic
        if (d.entity_type) html += '<div class="pop-meta">' + escHtml(d.entity_type) + '</div>';
      }
      return html;
    }

    function badgeColor(b) {
      const m = {deity:'#f6b93b',vampire:'#8b0000',necromancer:'#4b0082',werebeast:'#8b4513',ghost:'#c0c0c0',force:'#87ceeb'};
      return (m[b] || '#44403c') + ';color:#fafaf9';
    }

    function escHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    document.addEventListener('DOMContentLoaded', initPopovers);
    // Re-init after dynamic content loads
    window.initPopovers = initPopovers;
  })();
  </script>
  
</body>
