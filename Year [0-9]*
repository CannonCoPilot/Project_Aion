<script>
(function() {
  let gsTimer = null;
  let gsActiveIdx = -1;
  let gsResults = [];

  window.debounceGlobalSearch = function() {
    clearTimeout(gsTimer);
    gsTimer = setTimeout(doGlobalSearch, 200);
  };

  async function doGlobalSearch() {
    const input = document.getElementById('global-search-input');
    const box = document.getElementById('global-search-results');
    const term = input.value.trim();
    if (term.length < 2) { box.classList.add('hidden'); gsResults = []; return; }

    try {
      const resp = await fetch('/api/search?term=' + encodeURIComponent(term) + '&limit=20');
      if (!resp.ok) { box.classList.add('hidden'); return; }
      gsResults = await resp.json();
      gsActiveIdx = -1;

      if (gsResults.length === 0) {
        box.innerHTML = '<div class="text-stone-500 text-xs px-3 py-3 text-center">No results found</div>';
      } else {
        box.innerHTML = gsResults.map((r, i) => {
          const cls = 'gs-type-' + (['hf','entity','site','artifact','region'].includes(r.type) ? r.type : 'default');
          return '<a href="' + r.url + '" class="gs-result" data-idx="' + i + '">'
            + '<span class="gs-type ' + cls + '">' + r.type_display + '</span>'
            + '<span class="text-stone-300">' + escapeHtml(r.name) + '</span>'
            + '</a>';
        }).join('');
      }
      box.classList.remove('hidden');
    } catch(e) { box.classList.add('hidden'); }
  }

  window.handleGlobalSearchKey = function(e) {
    const box = document.getElementById('global-search-results');
    if (box.classList.contains('hidden')) return;
    const items = box.querySelectorAll('.gs-result');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      gsActiveIdx = Math.min(gsActiveIdx + 1, items.length - 1);
      updateActive(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      gsActiveIdx = Math.max(gsActiveIdx - 1, -1);
      updateActive(items);
    } else if (e.key === 'Enter' && gsActiveIdx >= 0 && gsActiveIdx < gsResults.length) {
      e.preventDefault();
      window.location.href = gsResults[gsActiveIdx].url;
    } else if (e.key === 'Escape') {
      box.classList.add('hidden');
    }
  };

  function updateActive(items) {
    items.forEach((el, i) => el.classList.toggle('gs-active', i === gsActiveIdx));
    if (gsActiveIdx >= 0 && items[gsActiveIdx]) items[gsActiveIdx].scrollIntoView({block: 'nearest'});
  }

  function escapeHtml(s) {
    const d = document.createElement('div'); d.textContent = s; return d.innerHTML;
  }

  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('#global-search-container')) {
      document.getElementById('global-search-results').classList.add('hidden');
    }
  });
})();
</script>

